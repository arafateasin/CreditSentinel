# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Azure Cosmos DB ─────────────────────────────────────────────────────────
# Resource: creditsentineldb (Cosmos DB PostgreSQL)
COSMOSDB_ENDPOINT=https://creditsentineldb.documents.azure.com:443/
COSMOSDB_KEY=<your-cosmosdb-primary-key>
COSMOSDB_CONNECTION_STRING=AccountEndpoint=https://creditsentineldb.documents.azure.com:443/;AccountKey=<your-key>;
COSMOSDB_DATABASE_NAME=CreditSentinelDB

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
# Resource: creditsentinel2026 (Storage Account)
AZURE_STORAGE_ACCOUNT_NAME=creditsentinel2026
AZURE_STORAGE_ACCOUNT_KEY=<your-storage-account-key>
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=creditsentinel2026;AccountKey=<your-key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=ctos-pdfs

# ─── Azure Document Intelligence ─────────────────────────────────────────────
# Resource: doi-creditsentinel2026 (Document Intelligence)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://doi-creditsentinel2026.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=<your-document-intelligence-key>

# ─── Azure OpenAI (for LangGraph agents) ─────────────────────────────────────
# Resource: api-creditsentinel2026 (OpenAI or Azure OpenAI)
OPENAI_API_KEY=<your-openai-api-key>
# Optional: Use Azure OpenAI instead
# AZURE_OPENAI_ENDPOINT=https://api-creditsentinel2026.openai.azure.com/
# AZURE_OPENAI_API_KEY=<your-azure-openai-key>
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ─── Azure Static Web Apps ────────────────────────────────────────────────────
# Frontend deployment: dashboard-creditsentinel2026
AZURE_WEBAPP_NAME=dashboard-creditsentinel2026
AZURE_RESOURCE_GROUP=credit-sentinel-rg

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=<generate-a-long-random-string>
