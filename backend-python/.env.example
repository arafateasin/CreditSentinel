# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ─── Azure Cosmos DB ─────────────────────────────────────────────────────────
COSMOS_ENDPOINT=https://creditsentineldb.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key-here
COSMOS_DATABASE=CreditSentinelDB

# ─── Azure Blob Storage ──────────────────────────────────────────────────────
STORAGE_ACCOUNT_NAME=creditsentinel2026
STORAGE_ACCOUNT_KEY=your-storage-key-here
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=creditsentinel2026;AccountKey=your-key;EndpointSuffix=core.windows.net
STORAGE_CONTAINER=ctos-pdfs

# ─── Azure Document Intelligence ─────────────────────────────────────────────
DOC_INTEL_ENDPOINT=https://doi-creditsentinel2026.cognitiveservices.azure.com/
DOC_INTEL_KEY=your-doc-intel-key-here

# ─── Azure OpenAI (GPT-4o) ───────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://creditsentinel-ai.cognitiveservices.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ─── Authentication ──────────────────────────────────────────────────────────
DEMO_AUTH_TOKEN=credit-officer-token
